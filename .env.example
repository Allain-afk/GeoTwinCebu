# Copy this file to .env and fill in your values.
# Never commit .env to git.

# Supabase project URL (Settings → API → Project URL)
SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anon/public key (Settings → API → anon public)
SUPABASE_KEY=your-anon-key-here

# Name of the Supabase Storage bucket to use for GeoJSON cache
# Create this bucket manually in Supabase dashboard before running the seed script.
SUPABASE_BUCKET=geojson-cache
